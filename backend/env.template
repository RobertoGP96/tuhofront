# ============================================
# TUhoBackend - Variables de Entorno Django
# ============================================
# Copia este archivo a backend/.env y completa los valores según tu entorno
# IMPORTANTE: Nunca commitees el archivo .env real con valores reales

# ============================================
# SEGURIDAD (OBLIGATORIO)
# ============================================

# Clave secreta de Django (OBLIGATORIO EN PRODUCCIÓN)
# Genera una nueva clave con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# ⚠️ NUNCA uses el valor por defecto en producción
SECRET_KEY=django-insecure-CHANGE-THIS-TO-A-RANDOM-SECRET-KEY

# Modo de depuración (True para desarrollo, False para producción)
# ⚠️ SIEMPRE False en producción
DEBUG=True

# Hosts permitidos (separados por comas). En producción: tuho.uho.edu.cu,www.tuho.uho.edu.cu
ALLOWED_HOSTS=*

# Dominio del sitio (usado en emails y URLs absolutas)
DOMAIN=127.0.0.1:8000

# Orígenes permitidos para CSRF en producción (URLs completas con esquema)
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# URL del frontend (usada en emails de activación/recuperación y tracking público)
FRONTEND_URL=http://localhost:5173
PUBLIC_TRACKING_URL=http://localhost:5173/tracking

# ============================================
# BASE DE DATOS
# ============================================

# SQLite (desarrollo) se usa por defecto si no se define DATABASE_ENGINE.

# PostgreSQL (producción)
# DATABASE_ENGINE=django.db.backends.postgresql
# DATABASE_NAME=tuho_db
# DATABASE_USER=tuho_user
# DATABASE_PASSWORD=tuho_password
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_CONN_MAX_AGE=60

# ============================================
# CORREO ELECTRÓNICO
# ============================================

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True
EMAIL_HOST_USER=tu_correo@uho.edu.cu
EMAIL_HOST_PASSWORD=tu_contrasena_de_aplicacion
DEFAULT_FROM_EMAIL=noreply@uho.edu.cu
SUPPORT_EMAIL=soporte@uho.edu.cu

# ============================================
# CORS
# ============================================

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_ALL_ORIGINS=True

# ============================================
# JWT
# ============================================

JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=7

# ============================================
# THROTTLING (rate limiting DRF)
# ============================================

THROTTLE_ANON=30/min
THROTTLE_USER=120/min
THROTTLE_LOGIN=5/min
THROTTLE_REGISTER=10/hour
THROTTLE_PASSWORD_RESET=5/hour
THROTTLE_PUBLIC_TRACKING=20/min

# ============================================
# BRUTE FORCE PROTECTION (django-axes)
# ============================================

AXES_ENABLED=True
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_MINUTES=15

# ============================================
# CONTRASEÑAS
# ============================================

PASSWORD_MIN_LENGTH=8

# ============================================
# CELERY (tareas asíncronas / emails no bloqueantes)
# ============================================

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# True = ejecuta tareas síncronamente (sin worker), útil en desarrollo
CELERY_TASK_ALWAYS_EAGER=True

# ============================================
# BACKUPS
# ============================================

# Directorio donde se almacenan backups (creado automáticamente)
# DBBACKUP_LOCATION=/var/backups/tuho

# ============================================
# ARCHIVOS / UPLOADS
# ============================================

# Tamaño máximo de upload en bytes (default 10MB)
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760

# Lista de tipos MIME permitidos (separados por coma)
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,image/jpeg,image/png,image/webp,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/msword,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel

# ============================================
# DATOS INSTITUCIONALES (PDFs / emails)
# ============================================

INSTITUTION_NAME=Universidad de Holguín
INSTITUTION_SHORT_NAME=UHo
INSTITUTION_ADDRESS=Av. XX de Mayo s/n, Holguín, Cuba
INSTITUTION_WEBSITE=https://www.uho.edu.cu
INSTITUTION_LOGO=static/img/logo.png

# ============================================
# PRODUCCIÓN (habilitar cuando despliegues)
# ============================================

# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
